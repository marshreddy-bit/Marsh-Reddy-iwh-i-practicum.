doctype html
html 
    head 
        title= title
        meta(name="viewport" content="width=device-width, initial-scale=1")
        link(rel="stylesheet", href="/css/style.css")
    body    
        .form-wrapper
            h1 Update Custom Object
            a(href="/") Return to the homepage
            
            //- You'll add your form here in the next step
            form(method="POST")
                //- Example field (replace with your custom properties)
                label(for="new_property") New Property Value
                input(type="text" name="new_property" required)
                button(type="submit") Submit